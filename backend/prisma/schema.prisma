generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FieldStatus {
  RECOGNIZED
  UNCERTAIN
  CONFLICTING
  CONFIRMED
  MODIFIED
  DISCARDED
}

enum RestaurantClassification {
  NEW
  RECOMMENDATION
}

enum MembershipRole {
  OWNER
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  googleId  String?  @unique
  createdAt DateTime @default(now())

  memberships   Membership[]
  decisionVotes DecisionVote[]

  @@map("users")
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  memberships      Membership[]
  invitations      Invitation[]
  restaurants      Restaurant[]
  categories       Category[]
  tags             Tag[]
  decisionProfiles DecisionProfile[]
  appSettings      AppSetting[]
  decisionRounds   DecisionRound[]

  @@map("workspaces")
}

model Membership {
  id          String         @id @default(uuid())
  userId      String
  workspaceId String
  role        MembershipRole @default(MEMBER)
  createdAt   DateTime       @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@map("memberships")
}

model Invitation {
  id              String           @id @default(uuid())
  workspaceId     String
  email           String
  role            MembershipRole   @default(MEMBER)
  token           String           @unique @default(uuid())
  status          InvitationStatus @default(PENDING)
  invitedByUserId String?
  createdAt       DateTime         @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

enum SourceType {
  WEBSITE
  SEARCH
  MAPS
  MENU
  REVIEW
  USER_PASTED_TEXT
  OPENSTREETMAP
  GOOGLE_PLACES
  GOOGLE_MAPS_LINK
  OTHER
}

enum SourceReliability {
  LOW
  MEDIUM
  HIGH
}

model Restaurant {
  id          String  @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  categories  String[]
  subcategories String[]
  address     String?
  district    String?
  latitude    Float?
  longitude   Float?
  website     String?
  googleMapsLink String?
  googlePlaceId  String?
  phone       String?
  openingHours Json?
  priceLevel  Int?
  distance    Float?
  tags        String[]
  signatureDishes String[]
  vegetarianOptions Boolean?
  veganOptions      Boolean?
  reservationRecommended Boolean?
  deliveryAvailable Boolean?
  takeawayAvailable Boolean?
  ambience    String[]
  suitability String[]
  personalRating Float?
  externalRating Float?
  notes       String?
  classification RestaurantClassification?
  favorite    Boolean @default(false)
  blacklisted Boolean @default(false)
  lastVisitedAt DateTime?
  fieldStatuses    Json?
  confidenceByField Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sources         RestaurantSource[]
  extractedFacts  ExtractedFact[]
  visits          RestaurantVisit[]
  suggestions     SuggestionHistory[]
  decisionRounds  DecisionRound[]

  @@unique([workspaceId, googlePlaceId])
  @@map("restaurants")
}

model RestaurantSource {
  id           String   @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  type         SourceType
  url          String?
  title        String?
  retrievedAt  DateTime
  reliability  SourceReliability

  createdAt    DateTime @default(now())

  @@map("restaurant_sources")
}

model ExtractedFact {
  id           String   @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  field        String
  value        Json
  sourceType   SourceType
  sourceUrl    String?
  confidence   Float
  explanation  String
  status       FieldStatus @default(RECOGNIZED)

  createdAt    DateTime @default(now())

  @@map("extracted_facts")
}

model RestaurantVisit {
  id           String   @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  visitedAt    DateTime
  rating       Float?
  notes        String?

  createdAt    DateTime @default(now())

  @@map("restaurant_visits")
}

model DecisionProfile {
  id          String  @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  filters     Json
  weights     Json
  randomFactor Float  @default(0.2)
  repeatBlockDays Int @default(14)
  suggestionCount Int @default(3)
  isDefault   Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  suggestions SuggestionHistory[]

  @@unique([workspaceId, name])
  @@map("decision_profiles")
}

model Category {
  id   String @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name String

  @@unique([workspaceId, name])
  @@map("categories")
}

model Tag {
  id   String @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name String

  @@unique([workspaceId, name])
  @@map("tags")
}

model Classification {
  id          String  @id @default(uuid())
  key         String  @unique
  label       String
  description String?
  rules       Json?

  @@map("classifications")
}

model AppSetting {
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  key   String
  value Json

  @@id([workspaceId, key])
  @@map("app_settings")
}

model AnalysisRun {
  id         String   @id @default(uuid())
  analyzer   String
  input      Json
  result     Json
  warnings   String[]
  createdAt  DateTime @default(now())

  @@map("analysis_runs")
}

enum DecisionRoundStatus {
  OPEN
  ACCEPTED
  REJECTED
  CANCELLED
}

// A group decision: one member puts a suggested restaurant up for a vote,
// the other members vote yes/no. One open round per workspace at a time.
model DecisionRound {
  id              String              @id @default(uuid())
  workspaceId     String
  workspace       Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  restaurantId    String
  restaurant      Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdByUserId String
  status          DecisionRoundStatus @default(OPEN)
  createdAt       DateTime            @default(now())
  closedAt        DateTime?

  votes DecisionVote[]

  @@map("decision_rounds")
}

model DecisionVote {
  id        String   @id @default(uuid())
  roundId   String
  round     DecisionRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vote      Boolean
  createdAt DateTime @default(now())

  @@unique([roundId, userId])
  @@map("decision_votes")
}

model SuggestionHistory {
  id               String   @id @default(uuid())
  restaurantId     String
  restaurant       Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  decisionProfileId String?
  decisionProfile  DecisionProfile? @relation(fields: [decisionProfileId], references: [id])
  mode             String
  reasoning        String[]
  accepted         Boolean?
  createdAt        DateTime @default(now())

  @@map("suggestion_history")
}
