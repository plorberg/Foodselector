DATABASE_URL=
PORT=4000
APP_ENV=development
# Secret used to sign login tokens (JWT). Use a long random string.
JWT_SECRET=
# Google OAuth client id (type "Web"). Used to verify Google sign-in tokens. Not a secret.
GOOGLE_CLIENT_ID=
# Dev only: enables POST /api/auth/dev-login for local testing. NEVER enable in production.
ENABLE_DEV_LOGIN=
# Optional: SMTP for invitation emails, e.g. smtps://user:pass@smtp.example.com:465
# Without SMTP_URL + EMAIL_FROM no emails are sent — invitations then work via shareable links.
SMTP_URL=
EMAIL_FROM=
# Public URL of the frontend, used for invite links in emails (default: first CORS_ORIGIN).
APP_BASE_URL=
OPENAI_API_KEY=
GOOGLE_PLACES_API_KEY=
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
CORS_ORIGIN=http://localhost:5173
